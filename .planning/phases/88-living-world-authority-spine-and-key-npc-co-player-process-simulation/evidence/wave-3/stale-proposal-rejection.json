      "expiresAtWorldTimeMinutes": 5,
      "result": {
        "status": "rejected",
        "reason": "expired"
      }
    },
    {
      "name": "proposal created before done cannot commit after a later tool commit",
      "doneBoundaryWorldVersion": 0,
      "currentWorldVersionAtCommit": 1,
      "result": {
        "status": "rejected",
        "reason": "stale_base_world_version",
